gitignore
# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
*.dll

# Jupyter Notebook checkpoints
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# Temporary files
*.tmp
*.bak
*.swp
*.swo
*~

# Local data folders (игнорируем папки с данными)
python_path/Downloads/
python_path/data/
python_path/results/
python_path/reports_old/

# Old script versions (игнорируем старые версии скриптов)
python_path/hw_filesystem_*.py
python_path/*_v*.py
!python_path/hw_filesystem_v.5.py  # кроме финальной версии (раскомментируй если нужно)

# IDE settings
.vscode/
.idea/